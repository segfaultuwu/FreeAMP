<ui:FluentWindow x:Class="FreeAMP.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:res="clr-namespace:FreeAMP.Resources"
                 Title="{x:Static res:Strings.AppName}"
                 Width="1280"
                 Height="760"
                 MinWidth="980"
                 MinHeight="640"
                 WindowStartupLocation="CenterScreen"
                 Background="Transparent"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round"
                 ExtendsContentIntoTitleBar="True">

    <ui:FluentWindow.Resources>

        <SolidColorBrush x:Key="Bg" Color="#0B0B0F"/>
        <SolidColorBrush x:Key="Panel" Color="#15151C"/>
        <SolidColorBrush x:Key="Panel2" Color="#1B1B24"/>
        <SolidColorBrush x:Key="Border" Color="#2A2A36"/>
        <SolidColorBrush x:Key="Text" Color="#F5F5FA"/>
        <SolidColorBrush x:Key="Muted" Color="#9A9AA6"/>
        <SolidColorBrush x:Key="Accent" Color="#7C5CFF"/>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="Background" Value="{StaticResource Panel2}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

    </ui:FluentWindow.Resources>

    <Grid Background="#660B0B0F">

        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="130"/>
        </Grid.RowDefinitions>

        <!-- TITLEBAR -->

        <ui:TitleBar Grid.Row="0"
                     Title="FreeAMP"
                     ShowMinimize="True"
                     ShowMaximize="True"
                     ShowClose="True"/>

        <!-- CONTENT -->

        <Grid Grid.Row="1"
              Margin="16">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="270"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR -->

            <Border Grid.Column="0"
                    Background="{StaticResource Panel}"
                    CornerRadius="24"
                    BorderBrush="{StaticResource Border}"
                    BorderThickness="1">

                <DockPanel Margin="18">

                    <StackPanel DockPanel.Dock="Top"
                                Margin="0,4,0,32">

                        <TextBlock Text="{x:Static res:Strings.AppName}"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource Text}"/>

                        <TextBlock Text="{x:Static res:Strings.Subtitle}"
                                   Margin="0,4,0,0"
                                   Foreground="{StaticResource Muted}"/>
                    </StackPanel>

                    <StackPanel>

                        <Button Content="{x:Static res:Strings.Library}"
                                Height="48"
                                Margin="0,0,0,12"
                                Background="{StaticResource Accent}"
                                Click="LibraryButton_Click"/>

                        <Button Content="{x:Static res:Strings.Playlists}"
                                Height="48"
                                Margin="0,0,0,12"
                                Click="PlaylistsButton_Click"/>

                        <Button Content="{x:Static res:Strings.Albums}"
                                Height="48"
                                Margin="0,0,0,12"
                                Click="AlbumsButton_Click"/>

                        <Button Content="{x:Static res:Strings.Artists}"
                                Height="48"
                                Margin="0,0,0,12"
                                Click="ArtistsButton_Click"/>

                        <Button Content="YouTube"
                                Height="48"
                                Margin="0,0,0,12"
                                Click="YoutubeButton_Click"/>

                        <Button Content="{x:Static res:Strings.Settings}"
                                Height="48"
                                Click="SettingsButton_Click"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- VIEW HOST -->

            <Border Grid.Column="2"
                    Background="{StaticResource Panel}"
                    CornerRadius="24"
                    BorderBrush="{StaticResource Border}"
                    BorderThickness="1"
                    Padding="14">

                <ContentControl x:Name="MainContent"/>
            </Border>
        </Grid>

        <!-- PLAYER -->

        <Border Grid.Row="2"
                Margin="16,0,16,16"
                Background="{StaticResource Panel}"
                CornerRadius="24"
                BorderBrush="{StaticResource Border}"
                BorderThickness="1">

            <Grid Margin="22,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="240"/>
                </Grid.ColumnDefinitions>

                <!-- NOW PLAYING -->

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <Border Width="74"
                            Height="74"
                            CornerRadius="18"
                            Background="{StaticResource Panel2}"/>

                    <StackPanel Margin="16,0,0,0"
                                VerticalAlignment="Center">

                        <TextBlock x:Name="NowPlayingTitleText"
                                   Text="{x:Static res:Strings.NoTrackSelected}"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Text}"/>

                        <TextBlock x:Name="NowPlayingArtistText"
                                   Text="{x:Static res:Strings.UnknownArtist}"
                                   Margin="0,6,0,0"
                                   Foreground="{StaticResource Muted}"/>
                    </StackPanel>
                </StackPanel>

                <!-- CONTROLS -->

                <StackPanel Grid.Column="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">

                        <Button x:Name="PreviousButton"
                                Content="⏮"
                                Width="52"
                                Height="52"
                                Margin="5"/>

                        <Button x:Name="PlayPauseButton"
                                Content="▶"
                                Width="64"
                                Height="64"
                                Margin="5"
                                FontSize="18"
                                Background="{StaticResource Accent}"
                                Click="PlayPauseButton_Click"/>

                        <Button x:Name="NextButton"
                                Content="⏭"
                                Width="52"
                                Height="52"
                                Margin="5"/>
                    </StackPanel>

                    <Grid Margin="0,12,0,0">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52"/>
                            <ColumnDefinition Width="460"/>
                            <ColumnDefinition Width="52"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="CurrentTimeText"
                                   Text="0:00"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource Muted}"/>

                        <Slider x:Name="ProgressSlider"
                                Grid.Column="1"
                                Minimum="0"
                                Maximum="100"
                                Value="0"
                                PreviewMouseUp="ProgressSlider_PreviewMouseUp"/>

                        <TextBlock x:Name="DurationText"
                                   Grid.Column="2"
                                   Text="0:00"
                                   VerticalAlignment="Center"
                                   TextAlignment="Right"
                                   Foreground="{StaticResource Muted}"/>
                    </Grid>
                </StackPanel>

                <!-- VOLUME -->

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">

                    <TextBlock Text="{x:Static res:Strings.Volume}"
                               Margin="0,0,14,0"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource Muted}"/>

                    <Slider x:Name="VolumeSlider"
                            Width="130"
                            Minimum="0"
                            Maximum="100"
                            Value="70"
                            ValueChanged="VolumeSlider_ValueChanged"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>